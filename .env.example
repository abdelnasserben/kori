# -----------------------------------------------------------------------------
# Common application variables
# Copy this file to `.env` (Docker Compose) or export the variables in your shell.
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=local
KORI_SERVER_PORT=8081
KORI_JWT_AUDIENCE=kori-api

# -----------------------------------------------------------------------------
# Local host-based development defaults
# Use these values when you run the Spring Boot app directly on your machine.
# -----------------------------------------------------------------------------
KORI_DB_URL=jdbc:postgresql://localhost:5432/kori
KORI_DB_USERNAME=kori
KORI_DB_PASSWORD=kori
KORI_JWT_ISSUER_URI=http://localhost:8080/realms/kori

# -----------------------------------------------------------------------------
# Local Docker Compose infrastructure examples
# PostgreSQL hosts both the application database and a dedicated Keycloak database.
# -----------------------------------------------------------------------------
POSTGRES_DB=kori
POSTGRES_USER=kori
POSTGRES_PASSWORD=change-me
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USERNAME=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_REALM=kori
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_BIND_PORT=8080

# Place a realm export (for example `kori-realm.json`) in `docker/keycloak/import/`
# to have it imported automatically on local startup.

# -----------------------------------------------------------------------------
# Production example values (replace placeholders in your deployment environment)
# -----------------------------------------------------------------------------
# SPRING_PROFILES_ACTIVE=prod
# KORI_SERVER_PORT=8080
# KORI_DB_URL=jdbc:postgresql://postgres.internal:5432/kori
# KORI_DB_USERNAME=<prod-db-user>
# KORI_DB_PASSWORD=<prod-db-password>
# KORI_JWT_ISSUER_URI=https://sso.example.com/realms/kori
# KORI_JWT_AUDIENCE=kori-api
